                        <script>
            var pageLevelDefinitionObj = {
                intent: 'Non-Article',
                contentType: 'Non-Article',
                networkCategory: 'Non-Article',
                primaryCategory: '',
                primaryTag: '',
                brandName: 'FextraLife',
                adsTemplate: 'manual',
                articleType: '',
                segment: '',
                articleLimitDrawer : document.cookie.split("; ").find(row => row.startsWith("unauthenicatedArticleLimitReached"))?.split('=')[1] === 'true' ? 'loaded' : false,
                userRef : "",
                loggedIn : false,
                plan : "",
                referrerOverride : "",
                engagementContainer : 'article-body'
            };

            window.sentinelData = window.sentinelData || [];
            function sentinelTrack(){sentinelData.push(arguments)};
            sentinelTrack('initTimestamp', Date.now());
            window.addEventListener('DOMContentLoaded', () => {
                sentinelTrack('footerTimestamp', Date.now());
            });

            sentinelSetup = {
                customTrackingContainer: 'article-body',

                userDimensions: {
                    plan : "",
                    userRef : "",
                    loggedIn : false
                },

                internalDimensions: {
                    referrerOverride : "",
                },

                dimensions: {
                    contentType: 'Non-Article',
                    adsTemplate: 'manual',
                    intent: 'Non-Article',
                    articleType: '',
                    segment: '',
                    primaryTag: '',
                    primaryCategory: '',
                    networkCategory: 'Non-Article',
                    publishDate: "",
                    republishDate: "",
                    system: ''
                }
            };

            sentinelTrack('config', sentinelSetup);
        </script>
